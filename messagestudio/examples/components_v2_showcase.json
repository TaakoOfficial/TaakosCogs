    {
      "type": 10,
      "content": "### Buttons\nPrimary, secondary, success, danger, and link buttons can share an Action Row. Custom buttons support persistent actions or safe ephemeral fallback responses."
    },
    {
      "type": 1,
      "components": [
        {
          "type": 2,
          "style": 1,
          "label": "Primary",
          "emoji": "🚀",
          "custom_id": "messagestudio_showcase_primary",
          "actions": [
            {
              "type": "reply",
              "content": "You clicked the persistent primary action, {user}!",
              "ephemeral": true
            }
          ]
        },
        {
          "type": 2,
          "style": 2,
          "label": "Secondary",
          "custom_id": "messagestudio_showcase_secondary",
          "response": "You clicked the secondary showcase button!"
        },
        {
          "type": 2,
          "style": 3,
          "label": "Success",
          "custom_id": "messagestudio_showcase_success",
          "response": "Success! MessageStudio handled this interaction."
        },
        {
          "type": 2,
          "style": 4,
          "label": "Danger",
          "custom_id": "messagestudio_showcase_danger",
          "response": "This is only a showcase; nothing was deleted."
        },
        {
          "type": 2,
          "style": 5,
          "label": "Discord Docs",
          "url": "https://discord.com/developers/docs/components/reference"
        }
      ]
    },
    {
      "type": 14,
      "divider": true,
      "spacing": 1
